{
  "realm": "metalshopping",
  "enabled": true,
  "displayName": "MetalShopping",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "clients": [
    {
      "clientId": "metalshopping-web",
      "name": "MetalShopping Web",
      "description": "Backend-owned MetalShopping web session client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "metalshopping-web-secret-change-me",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "frontchannelLogout": true,
      "rootUrl": "http://127.0.0.1:5173",
      "baseUrl": "http://127.0.0.1:5173",
      "redirectUris": [
        "http://127.0.0.1:8080/api/v1/auth/session/callback"
      ],
      "webOrigins": [
        "http://127.0.0.1:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://127.0.0.1:5173/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "ms_admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "MetalShopping",
      "lastName": "Admin",
      "email": "admin@metalshopping.local",
      "attributes": {
        "tenant_id": [
          "bootstrap-local"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "ChangeMe123!",
          "temporary": false
        }
      ]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "ms_viewer",
      "enabled": true,
      "emailVerified": true,
