{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.metalshopping.local/schema/catalog/create_product_request/v1",
  "title": "catalog_create_product_request_v1",
  "description": "Request payload for creating a catalog product.",
  "type": "object",
  "additionalProperties": false,
  "x-metalshopping": {
    "contract_name": "catalog_create_product_request_v1",
    "contract_status": "draft",
    "bounded_context": "catalog",
    "owner_team": "product_core"
  },
  "required": ["sku", "name"],
  "properties": {
    "sku": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "brand_name": { "type": "string" },
    "stock_profile_code": { "type": "string" },
    "primary_taxonomy_node_id": { "type": "string" },
    "identifiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identifier_type", "identifier_value"],
        "properties": {
          "identifier_type": { "type": "string", "minLength": 1 },
          "identifier_value": { "type": "string", "minLength": 1 },
          "source_system": { "type": "string" },
          "is_primary": { "type": "boolean" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive"]
    }
  }
}
