{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/suppliers_create_driver_manifest_request_v1.schema.json",
  "title": "SuppliersCreateDriverManifestRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "supplierCode",
    "family",
    "config"
  ],
  "properties": {
    "supplierCode": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "http",
        "playwright",
        "http_v1",
        "playwright_v1"
      ]
    },
    "config": {
      "oneOf": [
        {
          "$ref": "./supplier_driver_manifest_http_v1.schema.json"
        },
        {
          "$ref": "./supplier_driver_manifest_playwright_v1.schema.json"
        }
      ]
    }
  }
}
