{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/supplier_driver_manifest_http_v1.schema.json",
  "title": "SupplierDriverManifestHttpV1",
  "type": "object",
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "baseUrl"
      ]
    },
    {
      "required": [
        "endpointTemplate"
      ]
    }
  ],
  "properties": {
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "endpointTemplate": {
      "type": "string",
      "minLength": 1
    }
  }
}
