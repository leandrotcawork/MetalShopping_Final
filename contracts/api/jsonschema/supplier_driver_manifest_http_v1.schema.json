{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/supplier_driver_manifest_http_v1.schema.json",
  "title": "SupplierDriverManifestHttpV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "strategy"
  ],
  "oneOf": [
    {
      "properties": {
        "strategy": {
          "const": "http.mock.v1"
        }
      },
      "required": [
        "strategy",
        "endpointTemplate"
      ]
    },
    {
      "properties": {
        "strategy": {
          "const": "http.vtex_persisted_query.v1"
        }
      },
      "required": [
        "strategy",
        "baseUrl",
        "operationName",
        "sha256Hash"
      ]
    },
    {
      "properties": {
        "strategy": {
          "const": "http.html_search.v1"
        }
      },
      "required": [
        "strategy",
        "baseUrl",
        "searchUrlTemplate"
      ]
    },
    {
      "properties": {
        "strategy": {
          "const": "http.leroy_search_sellers.v1"
        }
      },
      "required": [
        "strategy",
        "searchUrlTemplate",
        "sellersUrlTemplate"
      ]
    },
    {
      "properties": {
        "strategy": {
          "const": "http.html_dom_first_card.v1"
        }
      },
      "required": [
        "strategy",
        "searchUrlTemplate",
        "cardRootHint"
      ]
    }
  ],
  "properties": {
    "strategy": {
      "type": "string",
      "enum": [
        "http.mock.v1",
        "http.vtex_persisted_query.v1",
        "http.html_search.v1",
        "http.leroy_search_sellers.v1",
        "http.html_dom_first_card.v1"
      ]
    },
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "endpointTemplate": {
      "type": "string",
      "minLength": 1
    },
    "searchUrlTemplate": {
      "type": "string",
      "minLength": 1
    },
    "sellersUrlTemplate": {
      "type": "string",
      "minLength": 1
    },
    "operationName": {
      "type": "string",
      "minLength": 1
    },
    "sha256Hash": {
      "type": "string",
      "minLength": 16
    },
    "lookupVariableName": {
      "type": "string",
      "minLength": 1
    },
    "extraVariables": {
      "type": "object"
    },
    "pricePath": {
      "type": "string",
      "minLength": 1
    },
    "sellerPath": {
      "type": "string",
      "minLength": 1
    },
    "channelPath": {
      "type": "string",
      "minLength": 1
    },
    "priceRegex": {
      "type": "string",
      "minLength": 1
    },
    "sellerRegex": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "sellerPickStrategy": {
      "type": "string",
      "enum": [
        "selected",
        "min_sale"
      ]
    },
    "cardRootHint": {
      "type": "string",
      "minLength": 1
    },
    "cardItemHint": {
      "type": "string",
      "minLength": 1
    },
    "titleHint": {
      "type": "string",
      "minLength": 1
    },
    "listPriceHint": {
      "type": "string",
      "minLength": 1
    },
    "calculatedPriceHint": {
      "type": "string",
      "minLength": 1
    },
    "pricePriority": {
      "type": "string",
      "enum": [
        "calculated_first",
        "sale_first"
      ]
    },
    "timeoutSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60
    },
    "maxRetries": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "maxConcurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "requestsPerSecond": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 10.0
    },
    "retryHttpStatuses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 100,
        "maximum": 599
      }
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
