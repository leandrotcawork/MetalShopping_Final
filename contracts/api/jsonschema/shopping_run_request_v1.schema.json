{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/shopping_run_request_v1.schema.json",
  "title": "ShoppingRunRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runRequestId",
    "status",
    "inputMode",
    "requestedAt",
    "requestedBy"
  ],
  "properties": {
    "runRequestId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "claimed", "running", "completed", "failed", "cancelled"]
    },
    "inputMode": {
      "type": "string",
      "enum": ["xlsx", "catalog"]
    },
    "requestedAt": {
      "type": "string",
      "minLength": 1
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    },
    "claimedAt": {
      "type": ["string", "null"]
    },
    "startedAt": {
      "type": ["string", "null"]
    },
    "finishedAt": {
      "type": ["string", "null"]
    },
    "workerId": {
      "type": ["string", "null"]
    },
    "runId": {
      "type": ["string", "null"]
    },
    "errorMessage": {
      "type": ["string", "null"]
    },
    "totalItems": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "processedItems": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "currentSupplierCode": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "currentProductId": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "currentProductLabel": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "progressUpdatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "catalogProductIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "xlsxFilePath": {
      "type": ["string", "null"]
    },
    "xlsxScopeIdentifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "resolvedCatalogProductIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unresolvedScopeIdentifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ambiguousScopeIdentifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
