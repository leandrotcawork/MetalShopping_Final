{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/supplier_driver_manifest_playwright_v1.schema.json",
  "title": "SupplierDriverManifestPlaywrightV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "strategy"
  ],
  "oneOf": [
    {
      "properties": {
        "strategy": {
          "const": "playwright.mock.v1"
        }
      },
      "required": [
        "strategy",
        "startUrl"
      ]
    },
    {
      "properties": {
        "strategy": {
          "const": "playwright.pdp_first.v1"
        }
      },
      "required": [
        "strategy",
        "pdpSelectors"
      ],
      "anyOf": [
        {
          "required": [
            "startUrl"
          ]
        },
        {
          "required": [
            "searchUrl"
          ]
        }
      ]
    }
  ],
  "properties": {
    "strategy": {
      "type": "string",
      "enum": [
        "playwright.mock.v1",
        "playwright.pdp_first.v1"
      ]
    },
    "startUrl": {
      "type": "string",
      "minLength": 1
    },
    "searchUrl": {
      "type": "string",
      "minLength": 1
    },
    "searchUrlTemplate": {
      "type": "string",
      "minLength": 1
    },
    "fallbackSearchUrl": {
      "type": "string",
      "minLength": 1
    },
    "fallbackSearchEnabled": {
      "type": "boolean"
    },
    "pdpSelectors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "headless": {
      "type": "boolean"
    },
    "waitUntil": {
      "type": "string",
      "enum": [
        "load",
        "domcontentloaded",
        "networkidle",
        "commit"
      ]
    },
    "timeoutSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 120
    },
    "maxRetries": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "tabs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "circuitBreakerThreshold": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    }
  }
}
