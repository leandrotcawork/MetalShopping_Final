{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.metalshopping.local/schema/erp_integrations/review_item/v1",
  "title": "ErpReviewItem",
  "type": "object",
  "required": ["review_id","tenant_id","instance_id","connector_type","entity_type","source_id","run_id","severity","reason_code","problem_summary","recommended_action","item_status","created_at"],
  "properties": {
    "review_id": {"type":"string"},
    "tenant_id": {"type":"string"},
    "instance_id": {"type":"string"},
    "connector_type": {"type":"string"},
    "entity_type": {"type":"string"},
    "source_id": {"type":"string"},
    "run_id": {"type":"string"},
    "severity": {"type":"string","enum":["info","warning","error","critical"]},
    "reason_code": {"type":"string"},
    "problem_summary": {"type":"string"},
    "raw_payload_ref": {"type":"string"},
    "staging_snapshot": {"type":["object","null"]},
    "reconciliation_output": {"type":["object","null"]},
    "recommended_action": {"type":"string"},
    "item_status": {"type":"string","enum":["open","resolved","dismissed"]},
    "resolved_at": {"type":["string","null"],"format":"date-time"},
    "resolved_by": {"type":["string","null"]},
    "created_at": {"type":"string","format":"date-time"}
  }
}
