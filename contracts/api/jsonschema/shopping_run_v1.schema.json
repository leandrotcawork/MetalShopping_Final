{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/shopping_run_v1.schema.json",
  "title": "ShoppingRunV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runId",
    "status",
    "startedAt",
    "processedItems",
    "totalItems"
  ],
  "properties": {
    "runId": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed"]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "processedItems": {
      "type": "integer",
      "minimum": 0
    },
    "totalItems": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string"
    }
  }
}
