{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.metalshopping.local/api/shopping_create_run_response_v1.schema.json",
  "title": "ShoppingCreateRunResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runRequestId",
    "status",
    "inputMode",
    "requestedAt",
    "requestedBy"
  ],
  "properties": {
    "runRequestId": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "claimed", "running", "completed", "failed", "cancelled"]
    },
    "inputMode": {
      "type": "string",
      "enum": ["xlsx", "catalog"]
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    }
  }
}

