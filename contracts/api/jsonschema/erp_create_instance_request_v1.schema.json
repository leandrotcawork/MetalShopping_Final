{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.metalshopping.local/schema/erp_integrations/create_instance_request/v1",
  "title": "ErpCreateInstanceRequest",
  "type": "object",
  "required": ["connector_type","display_name","connection","enabled_entities"],
  "properties": {
    "connector_type": {"type":"string","enum":["sankhya"]},
    "display_name": {"type":"string","minLength":1,"maxLength":200},
    "connection": {
      "type":"object",
      "required": ["kind","host","port","username","password_secret_ref"],
      "oneOf": [
        {"required": ["service_name"], "not": {"required": ["sid"]}},
        {"required": ["sid"], "not": {"required": ["service_name"]}}
      ],
      "properties": {
        "kind": {"type":"string","enum":["oracle"]},
        "host": {"type":"string","minLength":1},
        "port": {"type":"integer","minimum":1},
        "service_name": {"type":["string","null"],"minLength":1},
        "sid": {"type":["string","null"],"minLength":1},
        "username": {"type":"string","minLength":1},
        "password_secret_ref": {"type":"string","minLength":1},
        "connect_timeout_seconds": {"type":["integer","null"],"minimum":1},
        "fetch_batch_size": {"type":["integer","null"],"minimum":1},
        "entity_batch_size": {"type":["integer","null"],"minimum":1}
      }
    },
    "enabled_entities": {"type":"array","minItems":1,"items":{"type":"string","enum":["products","prices","costs","inventory","sales","purchases","customers","suppliers"]}},
    "sync_schedule": {"type":["string","null"]}
  }
}
