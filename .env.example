# MetalShopping server_core local runtime example
# Copy to `.env` and adjust credentials for your local machine.

# App runtime
APP_ENV=local
APP_PORT=8080
# Optional explicit allowlist for frontend origins.
# Defaults to http://127.0.0.1:5173 and http://localhost:5173 when APP_ENV=local.
# APP_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Authentication
# Supported values:
# - static: local bootstrap bearer token
# - jwt: JWT validation (HS256 or RS256)
MS_AUTH_MODE=static

# Static auth bootstrap
MS_AUTH_STATIC_BEARER_TOKEN=local-dev-token
MS_AUTH_STATIC_SUBJECT_ID=admin-local
MS_AUTH_STATIC_TENANT_ID=bootstrap-local
MS_AUTH_STATIC_EMAIL=admin@metalshopping.local
MS_AUTH_STATIC_NAME=MetalShopping Local Admin

# JWT auth example
# MS_AUTH_MODE=jwt
# MS_AUTH_JWT_ALGORITHM=HS256
# MS_AUTH_JWT_ISSUER=metalshopping-local
# MS_AUTH_JWT_AUDIENCE=metalshopping-api
# MS_AUTH_JWT_HMAC_SECRET=change-me
# MS_AUTH_JWT_PUBLIC_KEY_PEM=
# MS_AUTH_JWT_JWKS_URL=

# OIDC-backed web session example
# Keep MS_AUTH_MODE aligned with the token validator you expect from the issuer.
# MS_AUTH_WEB_SESSION_MODE=required
# Supported values: required, optional, disabled
# Default behavior when unset:
# - MS_AUTH_MODE=static => optional
# - otherwise => required
# MS_AUTH_MODE=jwt
# MS_AUTH_OIDC_AUTHORIZATION_URL=https://idp.example.com/oauth2/authorize
# MS_AUTH_OIDC_TOKEN_URL=https://idp.example.com/oauth2/token
# MS_AUTH_OIDC_CLIENT_ID=metalshopping-web
# MS_AUTH_OIDC_CLIENT_SECRET=
# MS_AUTH_OIDC_REDIRECT_URI=http://127.0.0.1:8080/api/v1/auth/session/callback
# MS_AUTH_OIDC_SCOPES=openid profile email
# MS_AUTH_OIDC_HTTP_TIMEOUT_SECONDS=10
# MS_AUTH_WEB_DEFAULT_RETURN_TO=/products
# MS_AUTH_WEB_LOGIN_STATE_TTL_MINUTES=10
# MS_AUTH_WEB_SESSION_COOKIE_NAME=ms_web_session
# MS_AUTH_WEB_STATE_COOKIE_NAME=ms_web_login_state
# MS_AUTH_WEB_CSRF_COOKIE_NAME=ms_web_csrf
# MS_AUTH_WEB_CSRF_HEADER_NAME=X-CSRF-Token
# MS_AUTH_WEB_CSRF_HMAC_SECRET=change-me-long-random-secret
# MS_AUTH_WEB_CSRF_TTL_MINUTES=30
# MS_AUTH_WEB_COOKIE_DOMAIN=
# MS_AUTH_WEB_COOKIE_PATH=/
# MS_AUTH_WEB_COOKIE_SAMESITE=lax

# Keycloak local bootstrap example
# See docs/KEYCLOAK_LOCAL_BOOTSTRAP.md for the full bootstrap order.
# MS_AUTH_WEB_SESSION_MODE=required
# MS_AUTH_MODE=jwt
# MS_AUTH_JWT_ALGORITHM=RS256
# MS_AUTH_JWT_ISSUER=http://127.0.0.1:18081/realms/metalshopping
# MS_AUTH_JWT_AUDIENCE=metalshopping-web
# MS_AUTH_JWT_JWKS_URL=http://127.0.0.1:18081/realms/metalshopping/protocol/openid-connect/certs
# MS_AUTH_OIDC_AUTHORIZATION_URL=http://127.0.0.1:18081/realms/metalshopping/protocol/openid-connect/auth
# MS_AUTH_OIDC_TOKEN_URL=http://127.0.0.1:18081/realms/metalshopping/protocol/openid-connect/token
# MS_AUTH_OIDC_CLIENT_ID=metalshopping-web
# MS_AUTH_OIDC_CLIENT_SECRET=metalshopping-web-secret-change-me
# MS_AUTH_OIDC_REDIRECT_URI=http://127.0.0.1:8080/api/v1/auth/session/callback
# MS_AUTH_OIDC_SCOPES=openid profile email
# MS_AUTH_OIDC_HTTP_TIMEOUT_SECONDS=10
# MS_AUTH_WEB_DEFAULT_RETURN_TO=/products
# MS_AUTH_WEB_LOGIN_STATE_TTL_MINUTES=10
# MS_AUTH_WEB_SESSION_COOKIE_NAME=ms_web_session
# MS_AUTH_WEB_STATE_COOKIE_NAME=ms_web_login_state
# MS_AUTH_WEB_CSRF_COOKIE_NAME=ms_web_csrf
# MS_AUTH_WEB_CSRF_HEADER_NAME=X-CSRF-Token
# MS_AUTH_WEB_CSRF_HMAC_SECRET=change-me-long-random-secret
# MS_AUTH_WEB_CSRF_TTL_MINUTES=30
# MS_AUTH_WEB_COOKIE_DOMAIN=
# MS_AUTH_WEB_COOKIE_PATH=/
# MS_AUTH_WEB_COOKIE_SAMESITE=lax

# Preferred Postgres configuration for local development.
# If DATABASE_URL is set, it overrides the PG* values below.
# DATABASE_URL=postgres://metalshopping_app:metalshopping_app@127.0.0.1:5432/metalshopping?sslmode=disable
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=metalshopping
PGUSER=metalshopping_app
PGPASSWORD=metalshopping_app
PGSSLMODE=disable

# Postgres pool tuning
MS_PG_MAX_OPEN_CONNS=25
MS_PG_MAX_IDLE_CONNS=25
MS_PG_CONN_MAX_LIFETIME_SECONDS=1800
MS_PG_CONN_MAX_IDLE_TIME_SECONDS=300
MS_PG_PING_TIMEOUT_SECONDS=5
