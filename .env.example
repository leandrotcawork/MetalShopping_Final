# MetalShopping server_core local runtime example
# Copy to `.env` and adjust credentials for your local machine.

# App runtime
APP_ENV=local
APP_PORT=8080
# Optional explicit allowlist for frontend origins.
# Defaults to http://127.0.0.1:5173 and http://localhost:5173 when APP_ENV=local.
# APP_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Authentication
# Supported values:
# - static: local bootstrap bearer token
# - jwt: JWT validation (HS256 or RS256)
MS_AUTH_MODE=static

# Static auth bootstrap
MS_AUTH_STATIC_BEARER_TOKEN=local-dev-token
MS_AUTH_STATIC_SUBJECT_ID=admin-local
MS_AUTH_STATIC_TENANT_ID=bootstrap-local
MS_AUTH_STATIC_EMAIL=admin@metalshopping.local
MS_AUTH_STATIC_NAME=MetalShopping Local Admin

# JWT auth example
# MS_AUTH_MODE=jwt
# MS_AUTH_JWT_ALGORITHM=HS256
# MS_AUTH_JWT_ISSUER=metalshopping-local
# MS_AUTH_JWT_AUDIENCE=metalshopping-api
# MS_AUTH_JWT_HMAC_SECRET=change-me
# MS_AUTH_JWT_PUBLIC_KEY_PEM=

# Preferred Postgres configuration for local development.
# If DATABASE_URL is set, it overrides the PG* values below.
# DATABASE_URL=postgres://metalshopping_app:metalshopping_app@127.0.0.1:5432/metalshopping?sslmode=disable
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=metalshopping
PGUSER=metalshopping_app
PGPASSWORD=metalshopping_app
PGSSLMODE=disable

# Postgres pool tuning
MS_PG_MAX_OPEN_CONNS=25
MS_PG_MAX_IDLE_CONNS=25
MS_PG_CONN_MAX_LIFETIME_SECONDS=1800
MS_PG_CONN_MAX_IDLE_TIME_SECONDS=300
MS_PG_PING_TIMEOUT_SECONDS=5
