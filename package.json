{
  "name": "metalshopping",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/generated-types",
    "packages/platform-sdk",
    "packages/ui",
    "packages/feature-products",
    "packages/feature-auth-session"
  ],
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.1"
  },
  "scripts": {
    "web:typecheck": "npm --workspace @metalshopping/web run typecheck",
    "web:build": "npm --workspace @metalshopping/web run build",
    "web:test": "npm --workspace @metalshopping/web run test"
  }
}
